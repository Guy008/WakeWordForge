# WakeWordForge — .gitignore

# Runtime workspace (large files, generated data)
workspace/
run_state.json

# Personal recordings — keep directory structure, ignore audio files
my_recordings/*
!my_recordings/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Trained model binaries (large — use Git LFS or copy manually)
*.onnx
*.tflite
*.npy
*.pt
*.pth
*.pkl

# Local dev / test scripts
test*.sh
test*.py
claude.md

# Archives
*.zip
*.7z
*.tar.gz
