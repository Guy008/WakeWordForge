# WakeWordForge — .gitignore

# Runtime workspace (large files, generated data)
workspace/
run_state.json

# Exceptions: keep the custom recording placeholder dirs
!workspace/
!workspace/positive_custom/
!workspace/negative_custom/
!workspace/positive_custom/.gitkeep
!workspace/negative_custom/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Model outputs (large binaries — track separately or via Git LFS)
*.onnx
*.tflite
*.npy
*.pt
*.pth
